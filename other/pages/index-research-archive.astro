---
import Layout from '../layouts/Page.astro';
import { Container, Button } from '@components/odyssey-theme';

const seo = {
	title: "Mapping Hao's Research",
	description:
		'An interactive archive of research projects exploring digital technology, migration, education, queer spaces, and AI across different parts of the world.',
};
---

<Layout {seo}>
	<Container>
		<section class="hero">
			<p class="eyebrow">Mapping Hao's Research</p>
			<h1>Digital Lives, Spaces, and Identities Across Places</h1>
			<p class="intro">
				An interactive archive of research projects exploring digital technology,
				migration, education, queer spaces, and AI across different parts of the
				world.
			</p>
			<div class="hero-actions">
				<Button href="/research-map">Research Map</Button>
				<Button href="/blog" outlined>Projects</Button>
			</div>
		</section>
	</Container>

	<Container>
		<section class="section">
			<h2>Research Themes</h2>
			<p class="section-intro">
				Core areas connecting technology, place, and social life across field sites
				and collaborations.
			</p>
			<div class="cards">
				<article class="card">
					<h3>Digital Technology</h3>
					<p>
						How digital platforms, AI, and media systems shape everyday life.
					</p>
				</article>
				<article class="card">
					<h3>Space and Mobility</h3>
					<p>
						Migration, international education, and the production of place.
					</p>
				</article>
				<article class="card">
					<h3>Identity and Community</h3>
					<p>
						Queer spaces, belonging, visibility, and social change.
					</p>
				</article>
			</div>
		</section>
	</Container>

	<Container>
		<section class="section map-preview">
			<h2>Research Locations</h2>
			<ul class="locations">
				<li>📍 Chengdu — Hybrid Queer Spaces</li>
				<li>📍 Nottingham — Hong Kong Experience</li>
				<li>📍 London — Global South PhD Students</li>
				<li>📍 Mongolia-China-Japan — International Student Mobility</li>
			</ul>
			<Button href="/research-map">Explore the Map</Button>
		</section>
	</Container>
</Layout>

<style>
	.hero {
		margin: 6rem 0 4rem;
		max-width: 760px;
	}
	.eyebrow {
		margin: 0;
		font-size: var(--font-size-sm);
		text-transform: uppercase;
		letter-spacing: 0;
		opacity: 0.7;
	}
	h1 {
		margin: 0.5rem 0 1rem;
	}
	.intro {
		font-size: var(--font-size-lg);
		line-height: 1.6;
	}
	.hero-actions {
		display: flex;
		gap: 0.75rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}
	.section {
		margin: 2.5rem 0 4rem;
	}
	.section-intro {
		margin-bottom: 1rem;
	}
	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.card {
		padding: 1rem;
		border: 1px solid var(--theme-outline);
		border-radius: 8px;
		background: var(--theme-surface-1);
	}
	.card h3 {
		margin-top: 0;
	}
	.locations {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		line-height: 1.8;
	}
	.locations li {
		padding: 0.35rem 0;
	}
	@media (max-width: 900px) {
		.cards {
			grid-template-columns: 1fr;
		}
		.hero {
			margin-top: 4rem;
		}
	}
</style>
