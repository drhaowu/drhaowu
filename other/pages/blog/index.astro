---
import Layout from '../../layouts/Page.astro';
import { Container } from '@components/odyssey-theme';

const seo = {
	title: "Projects | Mapping Hao's Research",
	description: 'Selected research projects and public-facing work.',
};
---

<Layout {seo}>
	<Container>
		<section class="page">
			<h1>Projects</h1>
			<p>
				Selected research projects and publications will be listed here. Check back
				soon for updates.
			</p>
		</section>
	</Container>
</Layout>

<style>
	.page {
		max-width: 760px;
		margin: 4rem 0;
	}
</style>
