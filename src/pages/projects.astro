---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
	{
		title: "数字空间中的酷儿文化研究",
		description: "探索在线社交媒体平台上的酷儿群体如何构建身份认同和社区归属感",
		image: "/img/project1.jpg",
		tags: ["数字人类学", "酷儿研究", "社区研究"],
		year: "2023-2024",
		status: "进行中"
	},
	{
		title: "边缘群体的数字赋权",
		description: "研究数字技术如何为边缘群体提供新的表达和组织方式",
		image: "/img/project2.jpg",
		tags: ["数字人类学", "社会运动", "赋权研究"],
		year: "2022-2023",
		status: "已完成"
	},
	{
		title: "酷儿纪录片系列",
		description: "通过纪录片记录和展现中国酷儿群体的生活故事",
		image: "/img/project3.jpg",
		tags: ["视觉人类学", "酷儿研究", "纪录片"],
		year: "2021-2022",
		status: "已完成"
	}
];
---

<BaseLayout title="Projects - Dr Hao Wu">
	<div class="max-w-4xl mx-auto">
		<h1 class="text-4xl font-bold mb-8">研究项目</h1>
		
		<div class="space-y-8">
			{projects.map(project => (
				<div class="bg-white rounded-lg overflow-hidden shadow-md">
					<div class="md:flex">
						<div class="md:flex-shrink-0">
							<img class="h-48 w-full object-cover md:w-48" src={project.image} alt={project.title} />
						</div>
						<div class="p-8">
							<div class="flex items-center justify-between">
								<h2 class="text-2xl font-semibold mb-2">{project.title}</h2>
								<span class={`px-3 py-1 rounded-full text-sm ${project.status === "进行中" ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800"}`}>
									{project.status}
								</span>
							</div>
							<p class="text-gray-600 mb-4">{project.description}</p>
							<div class="flex flex-wrap gap-2 mb-4">
								{project.tags.map(tag => (
									<span class="bg-gray-100 px-3 py-1 rounded-full text-sm text-gray-700">
										{tag}
									</span>
								))}
							</div>
							<div class="text-sm text-gray-500">{project.year}</div>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</BaseLayout> 