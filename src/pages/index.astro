---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout title="Dr Hao Wu">
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
		<!-- Featured Project -->
		<div class="col-span-full bg-white rounded-lg overflow-hidden shadow-md">
			<img src="/img/banner.jpg" alt="Featured Project" class="w-full h-64 object-cover" />
			<div class="p-6">
				<h2 class="text-2xl font-semibold mb-2">数字空间中的酷儿文化研究</h2>
				<p class="text-gray-600">探索在线社交媒体平台上的酷儿群体如何构建身份认同和社区归属感...</p>
			</div>
		</div>

		<!-- Project Cards -->
		<ProjectCard
			emoji="📚"
			title="最新发表"
			description="数字人类学视角下的性/别认同研究"
			status="2024"
		/>

		<ProjectCard
			emoji="🔬"
			title="当前项目"
			description="边缘群体的数字赋权研究"
			status="进行中"
		/>

		<ProjectCard
			emoji="🎥"
			title="纪录片"
			description="《边缘的声音》系列纪录片"
			status="2024"
		/>

		<ProjectCard
			emoji="🎙️"
			title="播客"
			description="数字人类学对话"
			status="即将推出"
		/>
	</div>
</BaseLayout> 