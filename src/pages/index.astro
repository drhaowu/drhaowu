---
import Layout from '../layouts/Page.astro';
import { Container, Button } from '@components/odyssey-theme';

const seo = {
	title: 'Dr Hao Wu',
	description: 'Personal website of Dr Hao Wu',
};
---

<Layout {seo}>
	<Container>
		<section class="hero">
			<p class="eyebrow">Personal Website</p>
			<h1>Dr Hao Wu</h1>
			<p class="intro">
				I work across research, product, and digital systems. This site shares
				selected completed work and public writing.
			</p>
			<div class="hero-actions">
				<Button href="/company/about">About</Button>
				<Button href="/blog" outlined>Selected Work</Button>
			</div>
		</section>
	</Container>

	<Container>
		<section class="section">
			<h2>Selected Completed Work</h2>
			<p class="section-intro">
				A focused snapshot of completed and publicly shareable output.
			</p>
			<div class="cards">
				<article class="card">
					<h3>Research and Writing</h3>
					<p>
						Published analyses and essays covering human-centered systems,
						technology, and practical implementation questions.
					</p>
				</article>
				<article class="card">
					<h3>Web and Product Delivery</h3>
					<p>
						End-to-end website and workflow builds, from planning and structure
						to implementation and maintenance.
					</p>
				</article>
				<article class="card">
					<h3>Operational Improvement</h3>
					<p>
						Process and tooling updates that reduce friction and improve delivery
						speed for ongoing projects.
					</p>
				</article>
			</div>
		</section>
	</Container>

	<Container>
		<section class="section">
			<h2>Current Focus</h2>
			<p>
				I keep in-progress work private by default. Public updates here are
				limited to finalized, shareable outcomes and reflections.
			</p>
			<Button href="/company/contact">Contact</Button>
		</section>
	</Container>
</Layout>

<style>
	.hero {
		margin: 6rem 0 4rem;
		max-width: 760px;
	}
	.eyebrow {
		margin: 0;
		font-size: var(--font-size-sm);
		text-transform: uppercase;
		letter-spacing: 0;
		opacity: 0.7;
	}
	h1 {
		margin: 0.5rem 0 1rem;
	}
	.intro {
		font-size: var(--font-size-lg);
		line-height: 1.6;
	}
	.hero-actions {
		display: flex;
		gap: 0.75rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}
	.section {
		margin: 2.5rem 0 4rem;
	}
	.section-intro {
		margin-bottom: 1rem;
	}
	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.card {
		padding: 1rem;
		border: 1px solid var(--theme-outline);
		border-radius: 8px;
		background: var(--theme-surface-1);
	}
	.card h3 {
		margin-top: 0;
	}
	@media (max-width: 900px) {
		.cards {
			grid-template-columns: 1fr;
		}
		.hero {
			margin-top: 4rem;
		}
	}
</style>
