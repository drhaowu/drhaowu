---
import HomeLayout from '../layouts/Home.astro';
import { settings } from '../config/settings';

const base = import.meta.env.BASE_URL;
const avatarSrc = `${base}assets/images/avatar.png`;
const displayName = 'DR HAO WU';

const seo = {
	title: displayName,
	description: settings.author.bio,
};
---

<HomeLayout {seo}>
	<div class="landing" aria-label={displayName}>
		<div class="landing__bg" aria-hidden="true">
			<div class="landing__orb landing__orb--1"></div>
			<div class="landing__orb landing__orb--2"></div>
			<div class="landing__orb landing__orb--3"></div>
		</div>

		<a class="landing__avatar" href={base} aria-label={displayName}>
			<img src={avatarSrc} alt="" width="72" height="72" />
		</a>

		<h1 class="landing__name">{displayName}</h1>
	</div>
</HomeLayout>

<style>
	.landing {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: 2rem 1.5rem 4rem;
		text-align: center;
		overflow: hidden;
		background: #f8fafc;
	}

	.landing__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
	}

	.landing__orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(72px);
		opacity: 0.55;
		will-change: transform;
	}

	.landing__orb--1 {
		width: min(70vw, 520px);
		height: min(70vw, 520px);
		top: -12%;
		left: -8%;
		background: radial-gradient(circle, #dbeafe 0%, transparent 70%);
		animation: drift-a 22s ease-in-out infinite;
	}

	.landing__orb--2 {
		width: min(65vw, 480px);
		height: min(65vw, 480px);
		bottom: -18%;
		right: -10%;
		background: radial-gradient(circle, #e9d5ff 0%, transparent 70%);
		animation: drift-b 26s ease-in-out infinite;
	}

	.landing__orb--3 {
		width: min(50vw, 360px);
		height: min(50vw, 360px);
		top: 38%;
		left: 42%;
		background: radial-gradient(circle, #ccfbf1 0%, transparent 70%);
		animation: drift-c 18s ease-in-out infinite;
	}

	@keyframes drift-a {
		0%,
		100% {
			transform: translate(0, 0) scale(1);
		}
		50% {
			transform: translate(12%, 18%) scale(1.08);
		}
	}

	@keyframes drift-b {
		0%,
		100% {
			transform: translate(0, 0) scale(1);
		}
		50% {
			transform: translate(-14%, -12%) scale(1.06);
		}
	}

	@keyframes drift-c {
		0%,
		100% {
			transform: translate(-50%, -50%) scale(1);
		}
		33% {
			transform: translate(-42%, -58%) scale(1.1);
		}
		66% {
			transform: translate(-58%, -44%) scale(0.95);
		}
	}

	.landing__avatar,
	.landing__name {
		position: relative;
		z-index: 1;
	}

	.landing__avatar {
		position: fixed;
		top: 1.25rem;
		right: 1.25rem;
		display: block;
		width: 4.5rem;
		height: 4.5rem;
		border-radius: 50%;
		overflow: hidden;
		border: 1px solid rgba(15, 23, 42, 0.08);
		background: #fff;
		box-shadow: 0 4px 24px rgba(15, 23, 42, 0.06);
		transition: transform 0.2s ease;
	}

	.landing__avatar:hover {
		transform: scale(1.04);
	}

	.landing__avatar img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.landing__name {
		margin: 0;
		max-width: 12ch;
		font-size: clamp(2.75rem, 13vw, 7.25rem);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: -0.02em;
		color: #0f172a;
	}

	@media (prefers-reduced-motion: reduce) {
		.landing__orb {
			animation: none;
		}
	}

	@media (max-width: 640px) {
		.landing__avatar {
			width: 3.5rem;
			height: 3.5rem;
		}
	}
</style>
