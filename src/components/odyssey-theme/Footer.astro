---
interface FooterLink {
	title: string;
	slug: string;
}

interface FooterList {
	title: string;
	items: FooterLink[];
}

interface FooterSocial {
	name: string;
	url: string;
	icon?: string;
}

interface Props {
	background?: string;
	color?: string;
	copyrightName?: string;
	footerSocials?: FooterSocial[];
	footerLists?: FooterList[];
	showPlug?: boolean;
}

const {
	background = 'var(--theme-surface-1)',
	color = 'var(--theme-on-surface-1)',
	copyrightName = '',
	footerSocials = [],
	footerLists = [],
	showPlug = false,
} = Astro.props;

const withBase = (link: string) =>
	link.startsWith('http') ? link : `${import.meta.env.BASE_URL}${link.replace(/^\//, '')}`;
---

<footer class="site-footer" style={`background:${background};color:${color};`}>
	<div class="site-footer__inner">
		<div class="site-footer__brand">
			<slot name="logo" />
			{
				footerSocials.length > 0 && (
					<div class="site-footer__socials">
						{footerSocials.map((social) => (
							<a href={social.url} target="_blank" rel="noopener noreferrer">
								{social.name}
							</a>
						))}
					</div>
				)
			}
		</div>

		{
			footerLists.map((list) => (
				<div class="site-footer__list">
					<h3>{list.title}</h3>
					<ul>
						{list.items.map((item) => (
							<li>
								<a href={withBase(item.slug)}>{item.title}</a>
							</li>
						))}
					</ul>
				</div>
			))
		}
	</div>

	<div class="site-footer__bottom">
		<p>© {new Date().getFullYear()} {copyrightName}</p>
		{showPlug && <p>Built with Astro</p>}
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 4rem;
		border-top: 1px solid var(--theme-outline);
	}

	.site-footer__inner {
		display: grid;
		grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
		gap: 2rem;
		width: min(100% - 2rem, 1120px);
		margin-inline: auto;
		padding: 2.5rem 1rem 1.5rem;
	}

	.site-footer__brand h3,
	.site-footer__list h3 {
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
	}

	.site-footer__list ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.site-footer__list li + li {
		margin-top: 0.35rem;
	}

	.site-footer__list a,
	.site-footer__socials a {
		color: inherit;
		text-decoration: none;
		opacity: 0.85;
	}

	.site-footer__list a:hover,
	.site-footer__socials a:hover {
		opacity: 1;
		color: var(--theme-primary);
	}

	.site-footer__socials {
		display: flex;
		gap: 0.75rem;
		margin-top: 0.75rem;
	}

	.site-footer__bottom {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		width: min(100% - 2rem, 1120px);
		margin-inline: auto;
		padding: 0 1rem 1.5rem;
		opacity: 0.75;
		font-size: 0.875rem;
	}

	@media (max-width: 900px) {
		.site-footer__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
