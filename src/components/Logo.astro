---
import { settings } from '../config/settings.js';

const homeUrl = `${import.meta.env.BASE_URL}`;
---

<a class="logo" href={homeUrl}>
	<span class="logo__title">{settings.site.title}</span>
</a>

<style>
	.logo {
		color: inherit;
		text-decoration: none;
	}

	.logo__title {
		font-weight: 700;
		font-size: 1rem;
	}
</style>
